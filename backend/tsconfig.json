{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
"include": [
  "src/**/*.ts",
  "routes/**/*.ts",
  "controllers/**/*.ts",
  "middleware/**/*.ts",
  "types/**/*.d.ts",
  "prisma.config.ts"
],
  "exclude": ["node_modules", "dist"]
}
